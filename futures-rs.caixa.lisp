   :body "[package]\nname = \"futures-example-functional\"\nversion = \"0.0.0\"\nedition = \"2018\"\npublish = false\n\n[dependencies]\nfutures = { path = \"../../futures\", features = [\"thread-pool\"] }\n\n[lints]\nworkspace = true\n"} {:path "examples/functional/src/main.rs"
